{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UI Intent Object",
  "description": "用户 UI 需求的结构化表示，用于流水线生成",
  "type": "object",
  "required": ["ui_type", "name"],
  "properties": {
    "ui_type": {
      "type": "string",
      "enum": ["hud", "popup", "inventory", "shop", "choice", "settings"],
      "description": "界面类型"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "英文标识符，小写字母开头，只能包含小写字母、数字、下划线"
    },
    "title": {
      "type": "string",
      "description": "界面标题（显示给用户的文本）"
    },
    "layout": {
      "type": "object",
      "properties": {
        "style": {
          "type": "string",
          "enum": ["fullscreen", "centered", "corner"],
          "default": "centered",
          "description": "布局风格"
        },
        "position": {
          "type": "string",
          "enum": ["top-left", "top-center", "top-right", "center", "bottom-left", "bottom-center", "bottom-right"],
          "default": "center",
          "description": "界面位置"
        },
        "size": {
          "type": "string",
          "enum": ["small", "medium", "large", "fullscreen"],
          "default": "medium",
          "description": "界面尺寸"
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["text", "button", "image", "progress", "list", "grid", "input"],
            "description": "组件类型"
          },
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "组件标识符"
          },
          "content": {
            "type": "string",
            "description": "文本内容（用于 text、button）"
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "数量（用于 grid、button 组等）"
          },
          "rows": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "description": "行数（用于 grid）"
          },
          "cols": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "description": "列数（用于 grid）"
          }
        }
      },
      "description": "组件列表"
    },
    "style": {
      "type": "object",
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["dark", "light", "transparent"],
          "default": "dark",
          "description": "主题风格"
        },
        "has_close_button": {
          "type": "boolean",
          "default": true,
          "description": "是否有关闭按钮"
        },
        "has_background": {
          "type": "boolean",
          "default": true,
          "description": "是否有背景"
        }
      }
    }
  },
  "additionalProperties": false
}
